/* Bookstore-inspired theme for {{ .ProjectName }} documentation */

:root {
  --border-width: 1px;
  --roundness: 6px;
}

/* Force accent colors to override Starlight defaults */
:root,
:root[data-theme='light'] {
  /* custom colors here */
}

:root[data-theme='dark'] {
  /* custom dark theme colors here */
}

/* COlor variable overrides go here */
/* Light mode */
:root {
}

/* Dark mode */
:root[data-theme='dark'] {
}


:root:not([data-theme='dark']) tr:hover {
  background: var(--sl-color-bg-inline-code) !important;
}

:root:not([data-theme='dark']) blockquote {
  background: var(--sl-color-bg-inline-code) !important;
  border-left-color: var(--sl-color-accent) !important;
  color: var(--sl-color-gray-3) !important;
}


/* Code blocks - aged parchment style */
pre {
  border-radius: var(--roundness);
  border: var(--border-width) solid var(--sl-color-hairline) !important;
  box-shadow: var(--sl-shadow-md);
}

/* Expressive code block overrides: styling directly on header and pre instead of the parent frame */
.expressive-code .frame {
  border: none !important;
  box-shadow: none !important;
  background: transparent !important;
}

.expressive-code figcaption.header:not(:empty) {
  border: var(--border-width) solid var(--sl-color-hairline) !important;
  border-radius: var(--roundness) var(--roundness) 0 0 !important;
}

.expressive-code figcaption.header:empty {
  display: none !important;
}

/* Standalone pre (when there is no header) */
.expressive-code pre {
  border: var(--border-width) solid var(--sl-color-hairline) !important;
  border-radius: var(--roundness) !important;
  box-shadow: var(--sl-shadow-md) !important;
}

/* Pre when preceded by a header */
.expressive-code figcaption.header:not(:empty) + pre {
  border-top: none !important;
  border-radius: 0 0 var(--roundness) var(--roundness) !important;
}

/* Ensure code blocks have borders on all sides */
pre code {
  display: block;
}

/* Inline code - subtle highlight */
code:not(pre code) {
  padding: 0.2em 0.4em;
  border-radius: 4px;
  font-size: 0.9em;
  background: var(--sl-color-bg-inline-code);
  border: 1px solid var(--sl-color-hairline-light);
}

/* Tables - classic ledger style */
.sl-markdown-content table {
  display: table;
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  border: var(--border-width) solid var(--sl-color-hairline);
  border-radius: var(--roundness);
  overflow: hidden;
  box-shadow: var(--sl-shadow-sm);
}

.sl-markdown-content th {
  background: var(--sl-color-bg-nav);
  font-weight: 600;
  text-transform: uppercase;
  font-size: 0.85em;
  letter-spacing: 0.05em;
  padding: 0.85rem 1rem;
  border-bottom: 2px solid var(--sl-color-hairline);
}

.sl-markdown-content td {
  padding: 0.75rem 1rem;
  border-top: var(--border-width) solid var(--sl-color-hairline-light);
}

.sl-markdown-content tr:hover {
  background: var(--sl-color-bg-inline-code);
}

/* Links - warm hover effect */
a {
  text-decoration-thickness: 1px;
  text-underline-offset: 3px;
  transition: color 0.2s ease, text-decoration-color 0.2s ease;
}

a:hover {
  color: var(--sl-color-accent-high);
  text-decoration-color: var(--sl-color-accent-high);
}

/* Navigation - library catalog feel */
nav a {
  border-radius: var(--roundness);
  transition: background-color 0.2s ease, color 0.2s ease;
  padding: 0.5rem 0.75rem;
}

nav a:hover {
  background-color: var(--sl-color-bg-inline-code);
}

nav a[aria-current='page'] {
  background-color: var(--sl-color-accent-low);
  color: var(--sl-color-white);
  font-weight: 600 !important;
}

:root[data-theme='dark'] nav a[aria-current='page'] {
  background-color: var(--sl-color-accent-low);
  color: var(--sl-color-white);
  font-weight: 600 !important;
}

/* Blockquotes - margin notes style */
blockquote {
  border-left: 3px solid var(--sl-color-accent);
  padding-left: 1.5rem;
  margin-left: 0;
  font-style: italic;
  color: var(--sl-color-gray-3);
  background: var(--sl-color-bg-inline-code);
  padding: 1rem 1rem 1rem 1.5rem;
  border-radius: 0 var(--roundness) var(--roundness) 0;
}

/* Cards and containers - book cover style */
.card, .sl-container {
  border-radius: var(--roundness);
  border: var(--border-width) solid var(--sl-color-hairline-light);
}

/* Better spacing for API docs */
.api-section {
  margin-top: 2rem;
  padding-top: 1.5rem;
  border-top: var(--border-width) solid var(--sl-color-hairline-light);
}

/* Header - bookstore sign aesthetic */
header {
  border-bottom: var(--border-width) solid var(--sl-color-hairline);
  background: var(--sl-color-bg-nav);
}

/* Search - card catalog style */
.search-input {
  border-radius: var(--roundness);
  border: var(--border-width) solid var(--sl-color-hairline);
  background: var(--sl-color-bg);
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.search-input:focus {
  border-color: var(--sl-color-accent);
  box-shadow: 0 0 0 3px var(--sl-color-accent-low);
  outline: none;
}

/* Buttons - warm interactive style */
button, .button {
  border-radius: var(--roundness);
  font-weight: 500;
  letter-spacing: 0.02em;
  transition: all 0.2s ease;
  border: var(--border-width) solid var(--sl-color-hairline);
}

button:hover, .button:hover {
  transform: translateY(-1px);
  box-shadow: var(--sl-shadow-lg);
  border-color: var(--sl-color-accent);
}

/* Content area - warm reading background */
main {
  background: var(--sl-color-bg);
}

/* Improve heading contrast */
h1, h2, h3, h4, h5, h6 {
  color: var(--sl-color-text);
  font-weight: 600;
}

/* Dark mode specific improvements */
:root[data-theme='dark'] h1,
:root[data-theme='dark'] h2,
:root[data-theme='dark'] h3,
:root[data-theme='dark'] h4,
:root[data-theme='dark'] h5,
:root[data-theme='dark'] h6 {
  color: var(--sl-color-gray-1);
}

/* Sidebar text in dark mode */
:root[data-theme='dark'] .sidebar {
  color: var(--sl-color-gray-1);
}

:root[data-theme='dark'] nav a {
  color: var(--sl-color-gray-2);
}

:root[data-theme='dark'] nav a:hover {
  color: var(--sl-color-gray-1);
}

/* Badge/tag styling - bookmarks */
.badge, .tag {
  background: var(--sl-color-accent-low);
  color: var(--sl-color-white);
  padding: 0.25rem 0.6rem;
  border-radius: 4px;
  font-size: 0.85em;
  font-weight: 500;
}

/* Remove borders from main content and right sidebar */
.main-frame,
.content-panel,
.right-sidebar,
.sl-markdown-content,
article {
  border: none !important;
  box-shadow: none !important;
}

/* Remove borders from "On this page" section */
.right-sidebar-panel,
.right-sidebar-container,
nav[aria-labelledby="starlight__on-this-page"] {
  box-shadow: none !important;
}

/* Clean up any container borders */
.sl-container {
  border: none !important;
}

/* Active state for "On this page" items */
.right-sidebar a[aria-current='true'],
.right-sidebar a[aria-current='page'] {
  color: var(--sl-color-accent) !important;
  font-weight: 600 !important;
  box-shadow: inset 3px 0 0 var(--sl-color-accent) !important;
}

:root:not([data-theme='dark']) .right-sidebar a[aria-current='true'],
:root:not([data-theme='dark']) .right-sidebar a[aria-current='page'] {
  color: var(--sl-color-accent) !important;
  box-shadow: inset 3px 0 0 var(--sl-color-accent) !important;
}

:root[data-theme='dark'] .right-sidebar a[aria-current='true'],
:root[data-theme='dark'] .right-sidebar a[aria-current='page'] {
  box-shadow: inset 3px 0 0 var(--sl-color-accent) !important;
}
