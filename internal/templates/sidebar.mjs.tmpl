import config from './config.mjs';

const apiReference = {
  label: 'API Reference',
  items: [
{{- range .APIPackages }}
    { label: '{{ . }}', link: '/api/{{ . }}' },
{{- end }}
    {
      label: 'Adapters',
      items: [],
    },
  ],
};

const sidebar = [
  { label: '{{ .ProjectName }}', link: '/' },
  {{- if .HasInstall }}
  { label: 'Install', link: '/install' },
  {{- end }}
  { label: 'Commands', items: [
    { label: '{{ .ProjectName }}', link: '/commands/{{ .ProjectName }}' },
{{ .CommandsJS }}
  ] },
  {{- if .HasConfig }}
  { label: 'Configuration', link: '/configuration' },
  {{- end }}
];

const isProduction = process.env.NODE_ENV === 'production';
if (!isProduction) {
  sidebar.push(apiReference);
}

export default sidebar;
